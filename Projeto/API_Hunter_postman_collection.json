  "event": [
    {
      "listen": "prerequest",
      "script": {
        "type": "text/javascript",
        "packages": {},
        "requests": {},
        "exec": [
          ""
        ]
      }
    },
    {
      "listen": "test",
      "script": {
        "type": "text/javascript",
        "packages": {},
        "requests": {},
        "exec": [
          "const method = pm.request.method;\r",
          "const response = pm.response;\r",
          "\r",
          "// GET\r",
          "if (method === 'GET') {\r",
          "    pm.test(\"Status code is 200\", function () {\r",
          "        pm.response.to.have.status(200);\r",
          "    });\r",
          "\r",
          "    pm.test(\"Status code name is OK\", function () {\r",
          "        pm.response.to.have.status(\"OK\");\r",
          "    });\r",
          "}\r",
          "\r",
          "// GET e POST\r",
          "if (method === 'GET' || method === 'POST') {\r",
          "    pm.test(\"Response time < 15000ms\", function () {\r",
          "        pm.expect(response.responseTime).to.be.below(15000);\r",
          "    });\r",
          "}\r",
          "\r",
          "// POST\r",
          "if (method === 'POST') {\r",
          "    pm.test(\"POST sucesso\", function () {\r",
          "        pm.expect(response.code).to.be.oneOf([200, 201, 202]);\r",
          "    });\r",
          "\r",
          "    pm.test(\"Status code name is Created\", function () {\r",
          "        pm.response.to.have.status(\"Created\");\r",
          "    });\r",
          "\r",
          "    // Só processa JSON se for JSON\r",
          "    if (response.headers.get(\"Content-Type\")?.includes(\"application/json\")) {\r",
          "        const body = response.json();\r",
          "\r",
          "        if (pm.info.requestName === 'POST - Criar Novo Lead') {\r",
          "            pm.environment.set('id_lead', body.data?.id);\r",
          "        }\r",
          "\r",
          "        if (pm.info.requestName === 'POST - Criar Novo Lead List') {\r",
          "            pm.environment.set('id_lead_list', body.data?.id);\r",
          "        }\r",
          "    }\r",
          "}\r",
          "\r",
          "// PUT e DELETE\r",
          "if (method === 'PUT' || method === 'DELETE') {\r",
          "    pm.test(\"Status code 204\", function () {\r",
          "        pm.response.to.have.status(204);\r",
          "    });\r",
          "\r",
          "    pm.test(\"Status code name No Content\", function () {\r",
          "        pm.response.to.have.status(\"No Content\");\r",
          "    });\r",
          "}"
        ]
      }
    }
